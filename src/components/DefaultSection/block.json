{
  "apiVersion": 3,
  "title": "Default Section",
  "name": "app/section",
  "category": "advanced",
  "icon": "star-filled",
  "keywords": ["divider", "block", "separator"],
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "attributes": {
    "id": {
      "type": "string",
      "default": ""
    },
    "marginTop": {
      "type": "number",
      "default": 24
    },
    "marginBottom": {
      "type": "number",
      "default": 24
    }
  },
  "supports": {
    "html": true,
    "align": ["left", "center", "right"],
    "customClassName": true
  }
}
